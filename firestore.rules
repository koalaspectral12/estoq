rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validCarCreate() {
      return request.resource.data.keys().hasOnly([
        'id',
        'userId',
        'name',
        'nameNormalized',
        'series',
        'seriesNormalized',
        'color',
        'year',
        'notes',
        'isFavorite',
        'photoData',
        'photoUrl',
        'syncStatus',
        'duplicateStatus',
        'duplicateCandidates',
        'createdAt',
        'updatedAt',
        'updatedAtServer'
      ])
      && request.resource.data.userId == request.auth.uid
      && request.resource.data.name is string
      && request.resource.data.name.size() > 0
      && request.resource.data.name.size() <= 120
      && request.resource.data.nameNormalized is string
      && request.resource.data.series is string
      && request.resource.data.seriesNormalized is string
      && request.resource.data.color is string
      && request.resource.data.year is string
      && request.resource.data.notes is string
      && request.resource.data.isFavorite is bool
      && request.resource.data.photoUrl is string
      && request.resource.data.syncStatus is string
      && request.resource.data.duplicateStatus is string
      && request.resource.data.duplicateCandidates is list;
    }

    match /cars/{carId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && validCarCreate();
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && validCarCreate();
      allow delete: if isOwner(resource.data.userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}